#!/usr/bin/env python3
"""SEP Sesam Special Agent for CheckMK.

Queries the SEP Sesam REST API and outputs agent sections for:
- Backup groups (status)
- Backup jobs (per-task status, discovered from backup groups)
- Datastores (status, space usage)
- License (expiration, edition, customer, volume)
- Server info (version, OS, database type)

Authentication via session-based login (POST /auth/login).
"""

import argparse
import json
import re
import sys
from datetime import datetime

try:
    import requests
except ImportError:
    sys.stderr.write("Error: 'requests' library not available\n")
    sys.exit(1)

try:
    import urllib3
    _URLLIB3_AVAILABLE = True
except ImportError:
    _URLLIB3_AVAILABLE = False


class SesamClient:
    def __init__(self, hostname, port, username, password, verify_ssl=True, timeout=30):
        self.base_url = f"https://{hostname}:{port}/sep/api/v2"
        self.verify_ssl = verify_ssl
        self.timeout = timeout
        self.session = requests.Session()
        self.session.headers.update({
            "Accept": "application/json",
            "Content-Type": "application/json",
        })
        if not verify_ssl and _URLLIB3_AVAILABLE:
            urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
        self._login(username, password)

    def _login(self, username, password):
        """Authenticate via session-based login and store session header."""
        url = f"{self.base_url}/auth/login"
        login_data = {"username": username, "secret": password, "type": "DEFAULT"}
        resp = self.session.post(
            url, json=login_data, verify=self.verify_ssl, timeout=self.timeout,
        )
        if resp.status_code != 200:
            detail = ""
            try:
                detail = resp.text[:200]
            except Exception:
                pass
            raise RuntimeError(
                f"Login failed (HTTP {resp.status_code}): {detail}"
            )
        session_id = resp.json().get("sessionId", "")
        if not session_id:
            raise RuntimeError("Login failed: no sessionId in response")
        self.session.headers.update({"X-SEP-Session": session_id})

    def get(self, endpoint):
        url = f"{self.base_url}{endpoint}"
        return self.session.get(url, verify=self.verify_ssl, timeout=self.timeout)

    def post(self, endpoint, data=None):
        url = f"{self.base_url}{endpoint}"
        return self.session.post(
            url, json=data or {}, verify=self.verify_ssl, timeout=self.timeout
        )


def fetch_backupgroups(client, groups):
    """Fetch backup group data via POST /backupgroups/find."""
    results = []
    try:
        resp = client.post("/backupgroups/find", {})
        if resp.status_code == 200:
            all_groups = resp.json()
            if isinstance(all_groups, list):
                group_set = set(groups) if groups else None
                for g in all_groups:
                    if not isinstance(g, dict) or not g.get("name"):
                        continue
                    if group_set and g["name"] not in group_set:
                        continue
                    results.append({
                        "name": g["name"],
                        "resultsSts": g.get("resultsSts", "UNKNOWN"),
                        "error": None,
                    })
        else:
            results.append({
                "name": "_error",
                "resultsSts": "ERROR",
                "error": f"HTTP {resp.status_code}",
            })
    except requests.RequestException as exc:
        results.append({
            "name": "_error",
            "resultsSts": "ERROR",
            "error": str(exc),
        })
    return results


def fetch_backupjobs(client, groups):
    """Fetch all backup tasks via POST /backups/findTasks, filtered by groups."""
    results = []
    try:
        resp = client.post("/backups/findTasks", {})
        if resp.status_code == 200:
            tasks = resp.json()
            if isinstance(tasks, list):
                group_set = set(groups) if groups else None
                for task in tasks:
                    if not isinstance(task, dict) or not task.get("name"):
                        continue
                    task_group = task.get("groupName", "")
                    if group_set and task_group not in group_set:
                        continue
                    results.append({
                        "name": task["name"],
                        "group": task_group,
                        "resultsSts": task.get("resultsSts", "UNKNOWN"),
                        "exec": task.get("exec", True),
                        "error": None,
                    })
        else:
            results.append({
                "name": "_error_findTasks",
                "group": "",
                "resultsSts": "ERROR",
                "exec": False,
                "error": f"HTTP {resp.status_code}",
            })
    except Exception as exc:
        results.append({
            "name": "_error_findTasks",
            "group": "",
            "resultsSts": "ERROR",
            "exec": False,
            "error": str(exc),
        })
    return results


def fetch_datastores(client, datastores):
    """Fetch datastore data. If datastores is empty, discovers all via POST /datastores/find."""
    results = []

    if not datastores:
        try:
            resp = client.post("/datastores/find", {})
            if resp.status_code == 200:
                data = resp.json()
                if isinstance(data, list):
                    datastores = [d.get("name") for d in data if d.get("name")]
        except Exception:
            pass

    for ds in datastores:
        try:
            resp = client.get(f"/datastores/{ds}")
            if resp.status_code == 200:
                data = resp.json()
                results.append({
                    "name": ds,
                    "status": data.get("status", "UNKNOWN"),
                    "free": data.get("free", "0"),
                    "used": data.get("used", "0"),
                    "total": data.get("total", "0"),
                    "error": None,
                })
            else:
                results.append({
                    "name": ds,
                    "status": "ERROR",
                    "free": "0",
                    "used": "0",
                    "total": "0",
                    "error": f"HTTP {resp.status_code}",
                })
        except requests.RequestException as exc:
            results.append({
                "name": ds,
                "status": "ERROR",
                "free": "0",
                "used": "0",
                "total": "0",
                "error": str(exc),
            })

    return results


def fetch_license(client):
    """Fetch license information including edition, customer, and volume."""
    try:
        resp = client.post("/licenses/info")
        if resp.status_code not in (200, 201):
            return {
                "expiration_date": None, "days_remaining": None,
                "edition": None, "customer": None,
                "volume_used_tb": None, "volume_total_tb": None,
                "error": f"HTTP {resp.status_code}",
            }

        # The response is a JSON array of strings, or plain text
        try:
            lines = resp.json()
            if not isinstance(lines, list):
                lines = resp.text.splitlines()
        except Exception:
            lines = resp.text.splitlines()

        text = "\n".join(str(line) for line in lines)

        # Expiration date
        expiration_date = None
        days_remaining = None
        match = re.search(r"Maintenance expiration date\s+(\d{4}-\d{2}-\d{2})", text)
        if match:
            expiration_str = match.group(1)
            expiration_date = expiration_str
            expiration_dt = datetime.strptime(expiration_str, "%Y-%m-%d")
            days_remaining = (expiration_dt - datetime.now()).days

        # Edition
        edition = None
        m = re.search(r"^Edition:\s*(.+)", text, re.MULTILINE)
        if m:
            edition = m.group(1).strip()

        # Customer
        customer = None
        m = re.search(r"^Customer\s+:\s*(.+)", text, re.MULTILINE)
        if m:
            customer = m.group(1).strip()

        # Volume usage (e.g. "   1.023 TB of 21  TB FrontSide")
        volume_used_tb = None
        volume_total_tb = None
        m = re.search(
            r"(\d+\.?\d*)\s*TB\s+of\s+(\d+\.?\d*)\s*TB\s+FrontSide",
            text,
            re.IGNORECASE,
        )
        if m:
            volume_used_tb = float(m.group(1))
            volume_total_tb = float(m.group(2))

        if expiration_date is None:
            return {
                "expiration_date": None, "days_remaining": None,
                "edition": edition, "customer": customer,
                "volume_used_tb": volume_used_tb, "volume_total_tb": volume_total_tb,
                "error": "No expiration date found in license response",
            }

        return {
            "expiration_date": expiration_date,
            "days_remaining": days_remaining,
            "edition": edition,
            "customer": customer,
            "volume_used_tb": volume_used_tb,
            "volume_total_tb": volume_total_tb,
            "error": None,
        }

    except Exception as exc:
        return {
            "expiration_date": None, "days_remaining": None,
            "edition": None, "customer": None,
            "volume_used_tb": None, "volume_total_tb": None,
            "error": str(exc),
        }


def fetch_server_info(client):
    """Fetch SEP Sesam server information."""
    try:
        resp = client.get("/server/info")
        if resp.status_code == 200:
            data = resp.json()
            return {
                "name": data.get("name"),
                "release": data.get("release"),
                "kernel": data.get("kernel"),
                "os": data.get("serverOs") or data.get("os"),
                "dbType": data.get("dbType"),
                "javaVersion": data.get("javaVersion"),
                "timezone": data.get("timezone"),
                "error": None,
            }
        return {
            "name": None, "release": None, "kernel": None,
            "os": None, "dbType": None, "javaVersion": None,
            "timezone": None, "error": f"HTTP {resp.status_code}",
        }
    except requests.RequestException as exc:
        return {
            "name": None, "release": None, "kernel": None,
            "os": None, "dbType": None, "javaVersion": None,
            "timezone": None, "error": str(exc),
        }


def _discover_group_names(client):
    """Return list of all backup group names from the API."""
    try:
        resp = client.post("/backupgroups/find", {})
        if resp.status_code == 200:
            data = resp.json()
            if isinstance(data, list):
                return [g.get("name") for g in data if g.get("name")]
    except Exception:
        pass
    return []


def main():
    parser = argparse.ArgumentParser(
        description="SEP Sesam Special Agent for CheckMK"
    )
    parser.add_argument(
        "--hostname", required=True,
        help="SEP Sesam server hostname or IP address",
    )
    parser.add_argument(
        "--port", type=int, default=11401,
        help="API port (default: 11401)",
    )
    parser.add_argument(
        "--username", required=True,
        help="SEP Sesam API username",
    )
    parser.add_argument(
        "--no-verify-ssl", action="store_true",
        help="Disable SSL certificate verification",
    )
    parser.add_argument(
        "--timeout", type=int, default=30,
        help="Request timeout in seconds (default: 30)",
    )
    parser.add_argument(
        "--backupgroups", nargs="*", default=[], metavar="NAME",
        help="Backup group names to monitor (default: auto-discover all)",
    )
    parser.add_argument(
        "--datastores", nargs="*", default=[], metavar="NAME",
        help="Datastore names to monitor (default: auto-discover all)",
    )
    parser.add_argument(
        "--password",
        help="SEP Sesam API password (if not provided, read from stdin)",
    )
    args = parser.parse_args()

    # Password from argument or stdin
    password = args.password or sys.stdin.read().strip()
    if not password:
        sys.stderr.write("Error: No password provided via --password or stdin\n")
        sys.exit(1)

    try:
        client = SesamClient(
            hostname=args.hostname,
            port=args.port,
            username=args.username,
            password=password,
            verify_ssl=not args.no_verify_ssl,
            timeout=args.timeout,
        )
    except Exception as exc:
        sys.stderr.write(f"Error: {exc}\n")
        sys.exit(1)

    # Resolve group list (auto-discover if none specified)
    group_names = args.backupgroups or _discover_group_names(client)

    # Backup groups section
    backupgroups = fetch_backupgroups(client, group_names)
    print("<<<sep_sesam_backupgroups:sep(0)>>>")
    print(json.dumps(backupgroups))

    # Backup jobs section
    backupjobs = fetch_backupjobs(client, group_names)
    print("<<<sep_sesam_backupjobs:sep(0)>>>")
    print(json.dumps(backupjobs))

    # Datastores section
    datastores = fetch_datastores(client, args.datastores)
    print("<<<sep_sesam_datastores:sep(0)>>>")
    print(json.dumps(datastores))

    # License section
    license_info = fetch_license(client)
    print("<<<sep_sesam_license:sep(0)>>>")
    print(json.dumps(license_info))

    # Server info section
    server_info = fetch_server_info(client)
    print("<<<sep_sesam_server_info:sep(0)>>>")
    print(json.dumps(server_info))


if __name__ == "__main__":
    main()
